APP_NAME="Bytové spoločenstvo Hlavná 12"
APP_URL=http://localhost:3000
APP_DOMAIN=localhost

# Database
DATABASE_URL=postgresql://postgres:zmenMaPlease123@localhost:5433/resiapp
POSTGRES_PASSWORD=zmenMaPlease123

# Auth
NEXTAUTH_SECRET=change-me-to-a-random-64-char-string-in-production-please-now
