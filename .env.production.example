# BytováApp — Production environment variables
# Copy to .env on your server: cp .env.production.example .env
# Then fill in real values

APP_NAME="Bytové spoločenstvo Hlavná 12"
APP_URL=https://yourdomain.sk
APP_DOMAIN=yourdomain.sk

# Database — generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Auth — generate with: openssl rand -base64 64
NEXTAUTH_SECRET=CHANGE_ME_RANDOM_SECRET_HERE
NEXTAUTH_URL=https://yourdomain.sk

# Language
LANGUAGE=sk

# Email (optional — for notifications)
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.sk